{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-dj",
  "account_id": "f0a597f0134f247bd793592dc8964233",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-28",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "ai": {
    "binding": "AI"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ai_dj_db",
      "database_id": "152ea7fc-ca1d-4f68-94f5-1e967e17d2b0"
    }
  ],
  "triggers": {
    "crons": ["0 7,9,18 * * *"]
  },
  "vars": {
    "DJ_NAME": "Claudio",
    "AI_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    "TTS_MODEL": "@cf/myshell-ai/melotts",
    "TTS_LANG": "zh",
    "MINIMAX_BASE_URL": "https://api.minimaxi.com/v1",
    "MINIMAX_TTS_MODEL": "speech-2.8-hd",
    "MINIMAX_TTS_VOICE_ID": "Friendly_Person",
    "EXA_BASE_URL": "https://api.exa.ai",
    "NETEASE_API_BASE": "https://ai-dj-production.up.railway.app",
    "LLM_BASE_URL": "https://api.deepseek.com/v1",
    "LLM_MODEL": "deepseek-v4-pro"
  }
}
